# ─── App ────────────────────────────────────────────────
APP_NAME=Glamping API
APP_PORT=3000
APP_ENV=development

# ─── Database (PostgreSQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=glamping_db
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# ─── Logger ─────────────────────────────────────────────
LOG_LEVEL=info

# ─── JWT / Auth ─────────────────────────────────────────
JWT_SECRET=secret
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=refresh-secret
JWT_REFRESH_EXPIRY=168h
